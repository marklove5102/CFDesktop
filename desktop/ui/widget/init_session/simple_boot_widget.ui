  <property name="styleSheet">
   <string notr="true">/* 背景渐变效果 */
QWidget#SimpleBootWidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #F5F5F5, stop:0.5 #FAFAFA, stop:1 #F0F0F0);
}

/* Logo 容器 */
#logoContainer {
    background-color: transparent;
}

/* 应用名称样式 */
#appNameLabel {
    color: #1A1A1A;
    font-weight: bold;
    background-color: transparent;
}

/* 标语样式 */
#sloganLabel {
    color: #666666;
    background-color: transparent;
}

/* 分段进度容器 */
#stepIndicatorContainer {
    background-color: transparent;
    padding: 10px;
}

/* 步骤标签样式 */
#stepLabelsContainer {
    background-color: transparent;
}

.stepLabel {
    color: #999999;
    font-size: 11px;
    background-color: transparent;
    qproperty-alignment: AlignCenter;
}

.stepLabel.active {
    color: #6751A4;
    font-weight: bold;
}

.stepLabel.completed {
    color: #6751A4;
}

/* 当前步骤描述 */
#currentStepLabel {
    color: #333333;
    background-color: transparent;
    qproperty-alignment: AlignCenter;
}

/* 版本和版权信息 */
#versionLabel, #copyrightLabel {
    color: #999999;
    font-size: 10px;
    background-color: transparent;
    qproperty-alignment: AlignCenter;
}</string>
