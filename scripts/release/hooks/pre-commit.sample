#!/bin/bash
# =============================================================================
# Git Pre-Commit Hook - 本地代码质量检查
# =============================================================================
#
# 安装方法: bash scripts/release/hooks/install_hooks.sh
#
# 检查内容:
#   1. 空白字符问题（Git内置）
#   2. C++代码格式（需要clang-format）
#
# 绕过方法: git commit --no-verify -m "message"
# =============================================================================

set -e

# =============================================================================
# 颜色定义
# =============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# =============================================================================
# 日志函数
# =============================================================================
log_info() {
    echo -e "${BLUE}>>>${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# =============================================================================
# 获取项目根目录
# =============================================================================
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# =============================================================================
# 1. 空白字符检查
# =============================================================================
echo ""
log_info "Pre-Commit Hook: 代码质量检查"
echo ""

# 检查暂存区是否有尾随空格
cd "$PROJECT_ROOT"

# Detect platform and use appropriate script
if [[ "$(uname -s)" == MINGW* ]] || [[ "$(uname -s)" == MSYS* ]] || [[ "$(uname -s)" == Git* ]]; then
    # Windows (Git Bash) - use PowerShell script
    PS_SCRIPT="$PROJECT_ROOT/scripts/develop/remove_trailing_space.ps1"
    if [[ -f "$PS_SCRIPT" ]]; then
        if ! pwsh "$PS_SCRIPT" -StagedCheck; then
            log_error "空白字符检查失败"
            echo ""
            echo "修复方法:"
            echo "  pwsh scripts/develop/remove_trailing_space.ps1 -Staged"
            echo ""
            echo -e "${YELLOW}提示: 使用 --no-verify 可跳过此检查（不推荐）${NC}"
            exit 1
        fi
    else
        log_warning "空白字符检查脚本不存在: $PS_SCRIPT"
    fi
else
    # Linux/macOS - use bash script
    BASH_SCRIPT="$PROJECT_ROOT/scripts/develop/remove_trailing_space.sh"
    if [[ -f "$BASH_SCRIPT" ]]; then
        if ! bash "$BASH_SCRIPT" --staged-check; then
            log_error "空白字符检查失败"
            echo ""
            echo "修复方法:"
            if [[ "$(uname -s)" == Darwin* ]]; then
                echo "  bash scripts/develop/remove_trailing_space.sh --staged"
            else
                echo "  bash scripts/develop/remove_trailing_space.sh --staged"
            fi
            echo ""
            echo -e "${YELLOW}提示: 使用 --no-verify 可跳过此检查（不推荐）${NC}"
            exit 1
        fi
    else
        log_warning "空白字符检查脚本不存在: $BASH_SCRIPT"
    fi
fi
log_success "空白字符检查通过"

# =============================================================================
# 2. C++ 格式化（如果 clang-format 可用）
# =============================================================================
if command -v clang-format >/dev/null 2>&1; then
    cd "$PROJECT_ROOT"

    # 获取暂存的 C/C++ 文件
    STAGED_CPP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|cc|cxx|h|hpp|hxx)$' || true)

    if [ -n "$STAGED_CPP_FILES" ]; then
        log_info "格式化暂存的 C/C++ 文件..."

        # 对每个暂存的 C/C++ 文件运行 clang-format
        echo "$STAGED_CPP_FILES" | while IFS= read -r file; do
            [ -z "$file" ] && continue
            [ ! -f "$file" ] && continue

            # 格式化文件
            clang-format -i "$file" 2>/dev/null || true
        done

        # 重新添加格式化后的文件到暂存区
        echo "$STAGED_CPP_FILES" | while IFS= read -r file; do
            [ -z "$file" ] && continue
            git add "$file" 2>/dev/null || true
        done

        log_success "C++ 文件已格式化"
    fi
fi

# =============================================================================
# 3. Doxygen 注释检查（如果 Python 可用）
# =============================================================================
if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then
    cd "$PROJECT_ROOT"

    # 检查是否有暂存的头文件
    STAGED_HEADER_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(h|hpp|hxx)$' || true)

    if [ -n "$STAGED_HEADER_FILES" ]; then
        log_info "检查 Doxygen 注释..."

        # 确定 Python 命令
        PYTHON_CMD="python3"
        if ! command -v python3 >/dev/null 2>&1; then
            PYTHON_CMD="python"
        fi

        # 运行 doxygen lint
        if ! "$PYTHON_CMD" "$PROJECT_ROOT/scripts/doxygen/lint.py"; then
            log_error "Doxygen 注释检查失败"
            echo ""
            echo "发现的违规已写入: FAILED_DOXYGEN.md"
            echo ""
            echo "修复方法:"
            echo "  1. 查看 FAILED_DOXYGEN.md 了解详细问题"
            echo "  2. 参考 document/DOXYGEN_REQUEST.md 添加/修复 Doxygen 注释"
            echo ""
            echo -e "${YELLOW}提示: 使用 --no-verify 可跳过此检查（不推荐）${NC}"
            exit 1
        fi

        log_success "Doxygen 注释检查通过"
    fi
else
    log_warning "未找到 Python，跳过 Doxygen 注释检查"
fi

# =============================================================================
# 完成
# =============================================================================
echo ""
log_success "Pre-Commit 检查全部通过"
echo ""
exit 0
